{
  // markdownlint config for saas-security-end
  // https://github.com/DavidAnson/markdownlint/blob/main/doc/Rules.md
  //
  // Philosophy: this repo is 95% prose + audit prompts in PT-BR/EN.
  // We keep rules that catch real issues and disable stylistic rules
  // that don't change how the content reads.

  "default": true,

  // ── Disabled (stylistic / content-incompatible) ────────────────────────────

  // MD013: line length — prompts and long tables exceed any reasonable limit
  "MD013": false,

  // MD022: blank lines around headings — purely cosmetic
  "MD022": false,

  // MD024: duplicate headings — every audit module uses "Prompt para executar:"
  // on purpose, scoped to its own ## section
  "MD024": false,

  // MD026: trailing punctuation in heading — "Prompt para executar:" intentional
  "MD026": false,

  // MD032: blanks around lists — cosmetic
  "MD032": false,

  // MD033: inline HTML — needed for emojis and structured callouts
  "MD033": false,

  // MD040: fenced code language — many code blocks contain audit prompts
  // (natural-language instructions for Claude), not source code
  "MD040": false,

  // MD041: first-line heading — PR template starts with ## intentionally
  "MD041": false,

  // MD060: table column style — varied table densities throughout the project
  "MD060": false
}
